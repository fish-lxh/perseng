shamefully-hoist=true
public-hoist-pattern[]=electron
public-hoist-pattern[]=electron-*

# Ensure postinstall scripts always run (needed for native modules like better-sqlite3)
enable-pre-post-scripts=true

# NPM registry mirror (China)
registry=https://registry.npmmirror.com

# Electron mirror configuration (China)
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/

# Node-gyp headers mirror for native module compilation
disturl=https://npmmirror.com/mirrors/node/

# Electron headers for native module rebuild (used by @electron/rebuild)
electron_custom_dir={{ version }}
ELECTRON_CUSTOM_DIR={{ version }}

# KNUTH-FIX 2026-07-13: better-sqlite3 prebuild 走国内镜像, 跳过 node-gyp 源码编译
# prebuild-install 读 npm_config_better_sqlite3_binary_host → registry.npmmirror.com
# URL 模式: https://registry.npmmirror.com/-/binary/better-sqlite3/v{version}/better-sqlite3-v{version}-electron-v{abi}-{platform}-{arch}.tar.gz
# 覆盖 Electron ABI 121-145, 跟 Electron 39 (ABI 140) 匹配。
better-sqlite3_binary_host=https://registry.npmmirror.com/-/binary/better-sqlite3
