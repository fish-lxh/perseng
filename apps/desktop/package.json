{
  "name": "@promptx/desktop",
  "version": "2.4.1",
  "description": "Perseng Desktop - Local AI prompt management application",
  "author": {
    "name": "Deepractice",
    "email": "sean@deepracticex.com"
  },
  "homepage": "https://github.com/Deepractice/Perseng",
  "repository": {
    "type": "git",
    "url": "https://github.com/Deepractice/Perseng.git"
  },
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "postinstall": "node scripts/install-electron.cjs",
    "prebuild": "node scripts/create-namespace-stub.cjs",
    "dev": "electron-vite dev",
    "build": "pnpm clean && electron-vite build",
    "build:force": "pnpm clean && electron-vite build",
    "preview": "electron-vite preview",
    "clean": "rimraf out dist release tsconfig.tsbuildinfo",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --config electron-builder-dev.yml",
    "package:mac:skip": "electron-builder --config electron-builder-dev.yml",
    "package:win": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npm_config_disturl=https://npmmirror.com/mirrors/node/ pnpm build && electron-builder --win",
    "package:linux": "pnpm build && electron-builder --linux",
    "postpackage": "node scripts/inject-stub-into-asar.cjs",
    "dist": "pnpm package:mac"
  },
  "dependencies": {
    "@agentxjs/network": "1.9.0",
    "@agentxjs/persistence": "1.9.0",
    "@agentxjs/queue": "1.9.0",
    "@agentxjs/runtime": "workspace:*",
    "@agentxjs/ui": "1.9.0",
    "@heroicons/react": "^2.2.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@monaco-editor/react": "^4.7.0",
    "@promptx/config": "workspace:*",
    "@promptx/core": "workspace:*",
    "@promptx/electron-storage": "workspace:*",
    "@promptx/events": "workspace:*",
    "@promptx/feishu-desktop": "workspace:*",
    "@promptx/mcp-office": "workspace:*",
    "@promptx/mcp-server": "workspace:*",
    "@promptx/mcp-workspace": "workspace:*",
    "@promptx/mcp-workspace-host": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "adm-zip": "^0.5.17",
    "agentxjs": "1.9.0",
    "auto-launch": "^5.0.6",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.5",
    "i18next": "^23.16.8",
    "lucide-react": "^0.552.0",
    "monaco-editor": "^0.52.2",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/auto-launch": "^5.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/fs-extra": "^11.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "39.8.10",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0"
  }
}
