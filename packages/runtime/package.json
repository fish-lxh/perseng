{
  "name": "@agentxjs/runtime",
  "version": "2.0.2",
  "description": "Runtime for AI Agents - Agent execution, SystemBus, Environment, and Repository",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@agentxjs/agent": "1.9.0",
    "@agentxjs/common": "1.9.0",
    "@agentxjs/persistence": "1.9.0",
    "@agentxjs/types": "1.9.0",
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "bun-dts": "^0.1.70"
  }
}
